# Example environment variables for MultiChat
# Copy this file to .env and fill your real values. Do NOT commit your real .env.

TWITCH_CHANNEL=TuCanal
YOUTUBE_API_KEY=your_youtube_api_key

# Opcion A: usar canal (busca el live activo automaticamente)
YOUTUBE_CHANNEL_ID=your_channel_id

# Opcion B: usar video especifico (si lo tienes)
YOUTUBE_VIDEO_ID=your_live_video_id

KICK_CHATROOM_ID=your_kick_chatroom_id

# Optional: puerto
PORT=3001